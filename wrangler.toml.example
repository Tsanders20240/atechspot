name = "main-secure-build"
compatibility_date = "2026-07-10"
pages_build_output_dir = "."

[vars]
ALLOWED_HOSTS = "www.aplustechspot.com"

# Secrets: TURNSTILE_SECRET_KEY, RESEND_API_KEY, FORM_TO_EMAIL, FORM_FROM_EMAIL

