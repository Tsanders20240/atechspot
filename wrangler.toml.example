# name = "FORM_RATE_LIMITER"
# namespace_id = "41001"
#   [ratelimits.simple]
#   limit = 3
#   period = 60

# [[kv_namespaces]]
# binding = "FORM_DEDUP"
# id = "REPLACE_WITH_KV_NAMESPACE_ID"
